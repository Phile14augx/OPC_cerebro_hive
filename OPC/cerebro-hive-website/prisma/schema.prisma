generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pgcrypto]
}

// -----------------------------------------------------------------------------
// IDENTITY & ACCESS (Multi-Tenant Core)
// -----------------------------------------------------------------------------

model Organization {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String @unique
  billingPlan String @default("free")

  workspaces Workspace[]
  users      User[]

  createdAt                      DateTime                         @default(now())
  updatedAt                      DateTime                         @updatedAt
  OrganizationTaxonomyAssignment OrganizationTaxonomyAssignment[]
}

model Workspace {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name String
  slug String @unique

  projects Project[]
  apiKeys  APIKey[]

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  Assessment Assessment[]
  
  resources  Resource[]
  policies   Policy[]

  @@index([organizationId])
}

model User {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?       @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  email        String  @unique
  passwordHash String?
  name         String?
  role         Role    @default(USER)

  auditEvents   AuditEvent[]
  assignedTasks Task[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  CandidateProfile CandidateProfile?
  RecruiterProfile RecruiterProfile?

  @@index([organizationId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  USER
}

model APIKey {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name      String
  keyHash   String    @unique // Hashed for security
  expiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([workspaceId])
}

// -----------------------------------------------------------------------------
// PLATFORM ENTITIES
// -----------------------------------------------------------------------------

model Project {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String
  description String?
  status      String  @default("active")

  agents    Agent[]
  documents KnowledgeDocument[]
  workflows Workflow[]

  epics   Epic[]
  tasks   Task[]
  sprints Sprint[]

  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  ProjectSkillRequirement ProjectSkillRequirement[]

  @@index([workspaceId])
}

model Agent {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name         String
  model        String  @default("gpt-4o")
  systemPrompt String? @db.Text

  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Conversation {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId String @db.Uuid
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  messages Json // Structured array of conversational messages

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
}

model KnowledgeDocument {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title    String
  content  String @db.Text
  metadata Json?

  // vector embedding placeholder for pgvector (once Prisma formally supports it natively without raw queries in preview)
  // embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Workflow {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name    String
  trigger String
  actions Json // Definition of automated steps

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Integration {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider String // e.g. "github", "jira", "slack"
  config   Json // Encrypted tokens or metadata

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// OBSERVABILITY & AUDIT
// -----------------------------------------------------------------------------

model AuditEvent {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String
  resource String
  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
}

// -----------------------------------------------------------------------------
// PM AGENT / APPLICATION DOMAIN
// -----------------------------------------------------------------------------

model Sprint {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name      String
  goal      String?
  startDate DateTime
  endDate   DateTime
  status    String   @default("planned") // planned, active, completed

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Epic {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String
  description String? @db.Text
  status      String  @default("open") // open, in-progress, done
  riskLevel   String? // low, medium, high
  storyPoints Int?

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Task {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  epicId    String? @db.Uuid
  epic      Epic?   @relation(fields: [epicId], references: [id], onDelete: SetNull)
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String
  description String? @db.Text
  status      String  @default("todo") // todo, in-progress, review, done
  storyPoints Int?

  assigneeId String? @db.Uuid
  assignee   User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  sprintId String? @db.Uuid
  sprint   Sprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  labels String[] // using Postgres scalar array

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([epicId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([sprintId])
}

// -----------------------------------------------------------------------------
// TALENT OS - ASSESSMENT PLATFORM
// -----------------------------------------------------------------------------

// 1. Unified Identity Profiles
model CandidateProfile {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  skills    String[] // Cache of accumulated skills
  resumeUrl String?

  attempts AssessmentAttempt[]

  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  SkillEvidence        SkillEvidence[]
  SkillProfileSnapshot SkillProfileSnapshot[]
  AssessmentSession    AssessmentSession[]
}

model RecruiterProfile {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Assessment Authoring
model Assessment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  title       String
  description String?
  status      String   @default("draft") // draft, published, archived
  tags        String[]

  versions  AssessmentVersion[]
  resources AssessmentResource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

model AssessmentResource {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId String     @db.Uuid
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  name       String
  type       String // image, starter_code, sql_dataset, pdf
  storageKey String // S3/Object storage reference path

  createdAt DateTime @default(now())

  @@index([assessmentId])
}

model AssessmentVersion {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId String     @db.Uuid
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  versionNumber Int
  manifestHash  String @unique // Cryptographic signature of the package

  schemaPayload   Json // The frozen compiled schema tree
  manifestPayload Json // Dependencies and metadata

  attempts AssessmentAttempt[]

  createdAt         DateTime            @default(now())
  createdByUserId   String?             @db.Uuid // Author
  AssessmentSession AssessmentSession[]

  @@unique([assessmentId, versionNumber])
}

// 3. Candidate Execution & Submissions
model AssessmentAttempt {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateProfileId String           @db.Uuid
  candidate          CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  assessmentVersionId String            @db.Uuid
  version             AssessmentVersion @relation(fields: [assessmentVersionId], references: [id], onDelete: Restrict)

  status      String    @default("started") // started, paused, resumed, running, abandoned, submitted
  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  statePayload Json? // Live widget states (autosave)

  submission      AssessmentSubmission?
  telemetryEvents TelemetryEvent[]

  @@index([candidateProfileId])
  @@index([assessmentVersionId])
}

model AssessmentSubmission {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attemptId String            @unique @db.Uuid
  attempt   AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  finalPayload Json // Frozen final answers/code

  evaluation EvaluationResult?

  createdAt     DateTime        @default(now())
  SkillEvidence SkillEvidence[]
}

model EvaluationResult {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissionId String               @unique @db.Uuid
  submission   AssessmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  deterministicScore Float
  aiReviewScore      Float?
  finalScore         Float

  aiSummary  String?  @db.Text
  strengths  String[]
  weaknesses String[]

  detailsPayload Json // Detailed widget-by-widget breakdown

  createdAt DateTime @default(now())
}

// 4. Telemetry and Analytics
model TelemetryEvent {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attemptId String            @db.Uuid
  attempt   AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  eventType String // WIDGET_EXECUTED, COMPILATION_ERROR, etc.
  widgetId  String?
  payload   Json?

  createdAt DateTime @default(now())

  @@index([attemptId])
  @@index([eventType])
}

// -----------------------------------------------------------------------------
// TALENT OS - PLATFORM INTELLIGENCE (PHASE 6)
// -----------------------------------------------------------------------------

// The overarching engineering category (e.g., "Frontend", "Backend", "Infrastructure")
model SkillDomain {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @unique
  description String?

  competencies SkillCompetency[]
}

// A specific technology or concept (e.g., "React", "Advanced SQL", "CI/CD")
model SkillCompetency {
  id       String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domainId String      @db.Uuid
  domain   SkillDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  name        String
  description String?

  capabilities SkillCapability[]

  @@unique([domainId, name])
}

// A demonstration of a skill (e.g., "Analytical Problem Solving", "Component Lifecycle Management")
model SkillCapability {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  competencyId String          @db.Uuid
  competency   SkillCompetency @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  name String

  evidences SkillEvidence[]

  @@unique([competencyId, name])
}

// Immutable evidence collected from an assessment widget or AI interview
model SkillEvidence {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capabilityId String          @db.Uuid
  capability   SkillCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  candidateProfileId String           @db.Uuid
  candidate          CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  submissionId String?               @db.Uuid
  submission   AssessmentSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  // Scoring
  score      Float // 0.0 to 100.0
  confidence Float // 0.0 to 1.0 (How confident is the AI/System in this evidence)

  // Explainability
  context String // "Correct ranking implementation in Window Function"
  source  String // "SQL Widget", "AI Interview", etc.

  createdAt DateTime @default(now())

  @@index([candidateProfileId])
  @@index([capabilityId])
}

// -----------------------------------------------------------------------------
// TALENT OS - ENTERPRISE INTELLIGENCE (PHASE 7)
// -----------------------------------------------------------------------------

// 1. Dedicated Vector Storage (Polymorphic)
model Embedding {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType String // e.g. "SkillCapability", "SkillEvidence", "ProjectRequirement"
  entityId   String @db.Uuid
  model      String @default("text-embedding-3-small")
  dimensions Int    @default(1536)

  // Note: For actual pgvector usage, we'd use Unsupported("vector(1536)")
  // Prisma is releasing native pgvector support soon. We map as Json for this schema iteration until the extension is active.
  embedding Json

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
}

// 2. Taxonomy Versioning
model TaxonomyVersion {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  versionLabel String  @unique // e.g., "V2.1"
  description  String?
  isActive     Boolean @default(true)

  assignments OrganizationTaxonomyAssignment[]

  createdAt DateTime @default(now())
}

model OrganizationTaxonomyAssignment {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  taxonomyVersionId String          @db.Uuid
  taxonomyVersion   TaxonomyVersion @relation(fields: [taxonomyVersionId], references: [id], onDelete: Restrict)

  effectiveFrom DateTime
  effectiveTo   DateTime?

  @@index([organizationId])
}

// 3. Strict Provenance for Evidence
model EvidenceSource {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type String // ASSESSMENT, INTERVIEW, REPOSITORY_ANALYSIS, MANUAL_OVERRIDE

  assessmentId String? @db.Uuid
  interviewId  String? @db.Uuid
  repositoryId String? @db.Uuid
  reviewerId   String? @db.Uuid

  metadata  Json? // Specific parameters of the source execution
  createdAt DateTime @default(now())
}

// 4. Temporal Evolution Snapshots
model SkillProfileSnapshot {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateProfileId String           @db.Uuid
  candidate          CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  snapshotDate DateTime
  graphPayload Json // The aggregated skill graph at that moment in time

  createdAt DateTime @default(now())

  @@unique([candidateProfileId, snapshotDate])
}

// 5. Enterprise Workforce Planning
model ProjectSkillRequirement {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  capabilityName String
  requiredLevel  Float // The minimum threshold (e.g. 75.0)
  importance     String @default("REQUIRED") // REQUIRED, NICE_TO_HAVE

  createdAt DateTime @default(now())

  @@index([projectId])
}

enum SessionStatus {
  INITIALIZED
  READY
  ACTIVE
  PAUSED
  RESUMED
  SUBMITTED
  EXPIRED
  TERMINATED
}

model AssessmentSession {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId         String            @db.Uuid
  candidate           CandidateProfile  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  assessmentVersionId String            @db.Uuid
  assessmentVersion   AssessmentVersion @relation(fields: [assessmentVersionId], references: [id], onDelete: Cascade)

  status    SessionStatus @default(INITIALIZED)
  startedAt DateTime?
  endedAt   DateTime?

  // Aggregated session metrics for AI consumption
  metrics Json?

  telemetryBatches SessionTelemetryBatch[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ExecutionJob ExecutionJob[]
}

model SessionTelemetryBatch {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String            @db.Uuid
  session   AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sequence  Int
  events    Json // The raw telemetry stream for this 5s batch

  createdAt DateTime @default(now())
}

enum ExecutionStatus {
  QUEUED
  ALLOCATING
  STARTING
  RUNNING
  STREAMING
  COMPLETED
  FAILED
  TIMED_OUT
  CANCELLED
}

model ExecutionJob {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String            @db.Uuid
  session   AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  status   ExecutionStatus @default(QUEUED)
  language String // e.g., "javascript"
  code     String          @db.Text

  // Execution Environment
  runtimeVersion String?
  containerImage String?

  artifacts ExecutionArtifact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExecutionArtifact {
  id    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId String       @db.Uuid
  job   ExecutionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  stdout   String? @db.Text
  stderr   String? @db.Text
  exitCode Int?

  // Execution Metrics
  queueWaitMs     Int?
  startupTimeMs   Int?
  executionTimeMs Int?
  memoryUsedBytes Int?

  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// HIVEFORGE PLATFORM & PROVISIONING
// -----------------------------------------------------------------------------

model Provider {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  config      Json?
  
  resources   Resource[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Blueprint {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  schema      Json     // Input schema
  template    Json     // Generation template
  
  resources   Resource[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Resource {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  providerId  String?  @db.Uuid
  provider    Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  blueprintId String?  @db.Uuid
  blueprint   Blueprint? @relation(fields: [blueprintId], references: [id], onDelete: SetNull)

  status      String   @default("pending")
  health      String   @default("unknown")
  cost        Float    @default(0.0)
  config      Json?

  deployments Deployment[]
  operations  Operation[]
  tags        Tag[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([providerId])
}

model Deployment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId  String   @db.Uuid
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  
  status      String   @default("requested")
  config      Json?

  operations  Operation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([resourceId])
}

model Operation {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId    String   @db.Uuid
  resource      Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  
  deploymentId  String?  @db.Uuid
  deployment    Deployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)

  status        String   @default("queued") // queued, running, provisioning, completed, failed
  type          String   // create, update, delete
  logs          Json?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([resourceId])
  @@index([deploymentId])
}

model Policy {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  rules       Json

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

model Tag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String
  value       String
  
  resourceId  String   @db.Uuid
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([resourceId, key])
  @@index([resourceId])
}
