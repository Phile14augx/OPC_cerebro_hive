{
  "name": "@cerebrohive/platform",
  "version": "0.1.0",
  "private": true,
  "description": "CerebroHive Enterprise AI Operating System — domain-driven modular monolith",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/kernel/persistence/migrate.ts",
    "openapi": "tsx src/dev/openapi/generate.ts",
    "cli": "tsx src/dev/cli/main.ts"
  },
  "engines": {
    "node": ">=20.9"
  },
  "dependencies": {
    "@fastify/swagger": "^9.8.1",
    "bullmq": "^5.80.9",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "kysely": "^0.29.4",
    "nats": "^2.29.3",
    "pg": "^8.22.0",
    "pino": "^9.14.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "fast-uri": ">=3.1.4",
    "esbuild": ">=0.27.2"
  }
}
