generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pgcrypto]
}

// -----------------------------------------------------------------------------
// PHASE 1: PLATFORM FOUNDATION
// -----------------------------------------------------------------------------

model Tenant {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String  @unique
  billingPlan String  @default("enterprise")
  isActive    Boolean @default(true)

  workspaces   Workspace[]
  members      TenantMember[]
  environments Environment[]
  apiKeys      APIKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workspace {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name String
  slug String @unique

  agents    Agent[]
  workflows Workflow[]
  projects  Project[]
  apiKeys   APIKey[]
  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model User {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String  @unique
  name      String?
  avatarUrl String?

  tenantMembers TenantMember[]
  sessions      Session[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TenantMember {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId   String @db.Uuid
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId])
}

model Role {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?

  permissions Permission[]
  members     TenantMember[]

  createdAt DateTime @default(now())
}

model Permission {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId   String @db.Uuid
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  action   String // e.g. "create:agent", "read:workspace"
  resource String

  @@unique([roleId, action, resource])
}

model APIKey {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String     @db.Uuid
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId String?    @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name      String
  keyHash   String    @unique
  expiresAt DateTime?

  createdAt DateTime @default(now())
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())
}

model AuditLog {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String?   @db.Uuid
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  action     String
  resource   String
  resourceId String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([userId])
}

model FeatureFlag {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String  @unique
  isEnabled Boolean @default(false)
  rules     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Environment {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String // dev, staging, prod

  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// PHASE 2: AI & AGENT DOMAIN
// -----------------------------------------------------------------------------

model Agent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String
  description String?
  avatarUrl   String?
  isActive    Boolean @default(true)

  versions      AgentVersion[]
  executions    AgentExecution[]
  conversations AgentConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

model AgentVersion {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId String @db.Uuid
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  version Int

  modelId String  @db.Uuid
  model   AIModel @relation(fields: [modelId], references: [id], onDelete: Restrict)

  instructions String @db.Text
  config       Json?

  capabilities AgentCapability[]
  tools        AgentTool[]
  prompts      PromptTemplate[]

  createdAt DateTime @default(now())

  @@unique([agentId, version])
}

model AgentCapability {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentVersionId String       @db.Uuid
  agentVersion   AgentVersion @relation(fields: [agentVersionId], references: [id], onDelete: Cascade)
  name           String
  config         Json?
}

model Tool {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?

  categoryId String?       @db.Uuid
  category   ToolCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  versions ToolVersion[]

  createdAt DateTime @default(now())
}

model ToolCategory {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name  String
  tools Tool[]
}

model ToolVersion {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  toolId  String @db.Uuid
  tool    Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  version Int

  schema      Json
  endpoint    String?
  handlerCode String? @db.Text

  agentVersions AgentTool[]

  createdAt DateTime @default(now())

  @@unique([toolId, version])
}

model AgentTool {
  agentVersionId String       @db.Uuid
  toolVersionId  String       @db.Uuid
  agentVersion   AgentVersion @relation(fields: [agentVersionId], references: [id], onDelete: Cascade)
  toolVersion    ToolVersion  @relation(fields: [toolVersionId], references: [id], onDelete: Cascade)

  @@id([agentVersionId, toolVersionId])
}

model PromptTemplate {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentVersionId String       @db.Uuid
  agentVersion   AgentVersion @relation(fields: [agentVersionId], references: [id], onDelete: Cascade)
  name           String
  template       String       @db.Text
  variables      Json?
}

model KnowledgeSource {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String
  type String // document, web, database
  uri  String

  collections KnowledgeCollectionSource[]
}

model KnowledgeCollection {
  id      String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name    String
  sources KnowledgeCollectionSource[]
}

model KnowledgeCollectionSource {
  collectionId String              @db.Uuid
  sourceId     String              @db.Uuid
  collection   KnowledgeCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  source       KnowledgeSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@id([collectionId, sourceId])
}

model Memory {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId String @db.Uuid
  context Json

  snapshots MemorySnapshot[]
}

model MemorySnapshot {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memoryId  String   @db.Uuid
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  payload   Json
  createdAt DateTime @default(now())
}

model AgentExecution {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId     String    @db.Uuid
  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  status      String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  metrics     Json?
}

model AgentConversation {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId String @db.Uuid
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  messages AgentMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentMessage {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String            @db.Uuid
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String            @db.Text
  metadata       Json?
  createdAt      DateTime          @default(now())
}

// -----------------------------------------------------------------------------
// PHASE 3: WORKFLOW DOMAIN
// -----------------------------------------------------------------------------

model WorkflowTemplate {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  definition Json
  workflows  Workflow[]
}

model Workflow {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String            @db.Uuid
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  templateId  String?           @db.Uuid
  template    WorkflowTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  name       String
  versions   WorkflowVersion[]
  executions WorkflowExecution[]
  schedules  Schedule[]
  triggers   Trigger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkflowVersion {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId String   @db.Uuid
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version    Int

  nodes WorkflowNode[]
  edges WorkflowEdge[]

  createdAt DateTime @default(now())

  @@unique([workflowId, version])
}

model WorkflowNode {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowVersionId String          @db.Uuid
  workflowVersion   WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  name              String
  type              String
  config            Json?

  outgoingEdges  WorkflowEdge[]          @relation("SourceNode")
  incomingEdges  WorkflowEdge[]          @relation("TargetNode")
  stepExecutions WorkflowStepExecution[]
}

model WorkflowEdge {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowVersionId String          @db.Uuid
  workflowVersion   WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  sourceNodeId      String          @db.Uuid
  sourceNode        WorkflowNode    @relation("SourceNode", fields: [sourceNodeId], references: [id])
  targetNodeId      String          @db.Uuid
  targetNode        WorkflowNode    @relation("TargetNode", fields: [targetNodeId], references: [id])
  condition         String?
}

model WorkflowExecution {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId  String    @db.Uuid
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status      String
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  runs WorkflowRun[]
}

model WorkflowRun {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowExecutionId String            @db.Uuid
  workflowExecution   WorkflowExecution @relation(fields: [workflowExecutionId], references: [id], onDelete: Cascade)
  status              String

  steps WorkflowStepExecution[]
}

model WorkflowStepExecution {
  id     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId  String       @db.Uuid
  run    WorkflowRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId String       @db.Uuid
  node   WorkflowNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  status      String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  logs        Json?
}

model Trigger {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId String   @db.Uuid
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  type       String
  config     Json
}

model Schedule {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId String   @db.Uuid
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  cron       String
  isActive   Boolean  @default(true)
}

model Event {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type      String
  payload   Json
  createdAt DateTime @default(now())
}

model Queue {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  status    String
  payload   Json
  createdAt DateTime @default(now())
}

model OutboxEvent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType     String
  aggregateType String
  aggregateId   String
  payload       Json
  status        String   @default("pending") // pending | published | failed
  error         String?  @db.Text
  createdAt     DateTime @default(now())
  publishedAt   DateTime?

  @@index([status])
}

model IdempotencyRecord {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  workspaceId  String?   @db.Uuid
  operation    String
  requestHash  String
  responseHash String?
  status       String    @default("pending") // pending | completed | failed
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?

  @@unique([tenantId, requestHash])
  @@index([requestHash])
}


// -----------------------------------------------------------------------------
// PHASE 4: PROJECT & SOFTWARE ENGINEERING DOMAIN
// -----------------------------------------------------------------------------

// ForgePhase: idea → planning → architecture → design → implementation → testing → deployment → monitoring
// ForgeStatus: draft | active | paused | completed | failed

model Project {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?

  // CerebroForge fields
  prompt       String?   @db.Text         // original natural-language build prompt
  forgeStatus  String    @default("draft") // draft | planning | architecting | designing | generating | testing | deploying | completed
  forgePhase   String    @default("idea")  // idea | planning | architecture | design | implementation | testing | deployment
  stack        Json?                       // { frontend, backend, mobile, database, infra }
  frameworks   String[]  @default([])
  actorList    String[]  @default([])
  totalModules Int       @default(0)
  totalStories Int       @default(0)
  totalApis    Int       @default(0)
  planJson     Json?                       // full structured plan from AI Planner
  archJson     Json?                       // architecture decisions JSON
  designTokens Json?                       // color palette, typography, etc.
  repoOwner    String?                     // GitHub owner/org
  repoName     String?                     // GitHub repo name
  repoUrl      String?
  activeAgents String[]  @default([])

  repositories  Repository[]
  sprints       Sprint[]
  milestones    Milestone[]
  modules       Module[]
  requirements  Requirement[]
  agentRuns     ForgeAgentRun[]
  artifacts     GeneratedArtifact[]
  forgeSessions ForgeSession[]
  archDecisions ArchitectureDecision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([forgeStatus])
}

model Repository {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  provider  String  @default("github") // github | gitlab | bitbucket
  defaultBranch String @default("main")

  branches Branch[]
  commits  Commit[]

  @@index([projectId])
}

model Branch {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  repositoryId String     @db.Uuid
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  name         String
  isDefault    Boolean    @default(false)
}

model Commit {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  repositoryId String     @db.Uuid
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  hash         String
  message      String
  author       String
  agentType    String?    // which agent made this commit
  createdAt    DateTime   @default(now())

  @@index([repositoryId])
}

model Module {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  priority    String   @default("medium") // critical | high | medium | low
  storyCount  Int      @default(0)
  apiCount    Int      @default(0)
  status      String   @default("pending") // pending | generating | done

  features Feature[]

  @@unique([projectId, name])
  @@index([projectId])
}

model Feature {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId        String  @db.Uuid
  module          Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  name            String
  description     String? @db.Text
  acceptanceCriteria String? @db.Text
  status          String  @default("pending")
  tasks    Task[]

  @@index([moduleId])
}

model Task {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  featureId String?  @db.Uuid
  feature   Feature? @relation(fields: [featureId], references: [id], onDelete: SetNull)
  sprintId  String?  @db.Uuid
  sprint    Sprint?  @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  title     String
  status    String   @default("todo") // todo | in_progress | done
  agentType String?
  estimatedHours Float?

  @@index([featureId])
}

model Sprint {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  goal      String?
  startDate DateTime?
  endDate   DateTime?
  tasks     Task[]

  @@index([projectId])
}

model Milestone {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String    @db.Uuid
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  dueDate   DateTime?
  weekLabel String?   // e.g. "Week 1-2"
  order     Int       @default(0)

  @@index([projectId])
}

model Requirement {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String  @db.Uuid
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String  // functional | non_functional | actor | entity | api_contract
  title       String
  description String? @db.Text
  priority    String  @default("medium")

  @@index([projectId])
  @@index([type])
}

model ArchitectureDecision {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  context   String  @db.Text
  decision  String  @db.Text
  status    String  @default("accepted") // proposed | accepted | deprecated | superseded
  pattern   String?  // microservices | monolith | ddd | cqrs | event_driven | hexagonal
  techStack Json?

  @@index([projectId])
}

model GeneratedArtifact {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String   // file | test | migration | dockerfile | k8s_manifest | terraform | openapi
  filePath    String?  // relative path in repo, e.g. "src/patients/patient.service.ts"
  language    String?  // typescript | python | go | sql | yaml | hcl
  serviceId   String?  // which microservice this belongs to
  content     String   @db.Text
  lineCount   Int      @default(0)
  status      String   @default("pending") // pending | generating | done | failed
  agentType   String?  // which agent produced this
  commitHash  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, filePath])
  @@index([projectId])
  @@index([status])
  @@index([serviceId])
}

// Tracks every AI agent invocation within a forge project
model ForgeAgentRun {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String   @db.Uuid
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentType    String   // pm | architect | ux | frontend | backend | mobile | desktop | chatbot | database | qa | security | devops | docs
  phase        String   // which ForgePhase triggered this run
  status       String   @default("queued") // queued | running | completed | failed
  systemPrompt String   @db.Text
  userPrompt   String   @db.Text
  response     String?  @db.Text
  tokensIn     Int      @default(0)
  tokensOut    Int      @default(0)
  durationMs   Int?
  model        String?  // which AI model was used
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([projectId])
  @@index([agentType])
  @@index([status])
}

// Active forge session — tracks SSE/WS connections
model ForgeSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String?  @db.Uuid
  phase       String   // current active phase
  isActive    Boolean  @default(true)
  clientId    String?  // SSE/WS client identifier
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([isActive])
}

// -----------------------------------------------------------------------------
// PHASE 5: KNOWLEDGE & RAG DOMAIN
// -----------------------------------------------------------------------------

model Document {
  id       String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title    String
  versions DocumentVersion[]
}

model DocumentVersion {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String   @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    Int
  content    String   @db.Text
  chunks     Chunk[]
}

model Chunk {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentVersionId String          @db.Uuid
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  content           String          @db.Text
  embeddings        Embedding[]
}

model Embedding {
  id      String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chunkId String                       @db.Uuid
  chunk   Chunk                        @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  vector  Unsupported("vector(1536)")?
  model   String
}

model VectorIndex {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name   String
  config Json
}

model Citation {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source String
  text   String @db.Text
}

model KnowledgeGraphNode {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label      String
  properties Json?
  outgoing   KnowledgeGraphEdge[] @relation("SourceKEdge")
  incoming   KnowledgeGraphEdge[] @relation("TargetKEdge")
}

model KnowledgeGraphEdge {
  id       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId String             @db.Uuid
